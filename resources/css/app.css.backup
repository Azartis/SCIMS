@tailwind base;
@tailwind components;
@tailwind utilities;
/* Custom OSCAS Branding Styles */
:root {
    --oscas-primary: #f97316;
    --oscas-gold: #eab308;
    --oscas-primary-dark: #c41e0e;
    --oscas-accent: #f97316;
}

/* Background Image Enhancement */
body {
    @apply antialiased;
}

/* Logo Animation */
@keyframes float {
    0%, 100% {
        transform: translateY(0px);
    }
    50% {
        transform: translateY(-10px);
    }
}

/* Welcome Page Enhancements */
.welcome-hero {
    @apply relative min-h-screen flex items-center justify-center;
}

/* Gradient Background with Logo */
.logo-bg {
    @apply relative;
    background-attachment: fixed;
    background-size: auto 400px;
    background-position: top right;
    background-repeat: no-repeat;
}

/* Button Styles */
.btn-primary {
    @apply px-6 py-3 bg-gradient-to-r from-yellow-500 to-amber-500 text-white rounded-lg font-semibold hover:from-yellow-600 hover:to-amber-600 transition shadow-lg hover:shadow-xl;
}

.btn-secondary {
    @apply px-6 py-3 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg font-semibold hover:from-blue-700 hover:to-blue-800 transition shadow-lg hover:shadow-xl;
}

.btn-outline {
    @apply px-4 py-2 text-gray-900 dark:text-gray-100 border border-gray-300 dark:border-gray-600 rounded-md text-sm hover:bg-gray-100 dark:hover:bg-gray-800 transition;
}

/* Card Hover Effects */
.card-hover {
    @apply transition duration-300 hover:shadow-lg hover:border-yellow-500 dark:hover:border-yellow-400;
}

/* Form Input Styling */
input[type="email"],
input[type="password"],
input[type="text"],
select,
textarea {
    @apply transition border-gray-300 dark:border-gray-600 focus:ring-yellow-500 focus:border-yellow-500;
}

input:focus,
select:focus,
textarea:focus {
    @apply ring-2 ring-yellow-500 ring-opacity-50;
}

/* Logo Image Effects */
.logo-image {
    @apply transition duration-300 hover:scale-110;
}

/* Auth Form Container */
.auth-container {
    @apply backdrop-blur-sm bg-white/95 dark:bg-gray-800/95;
}

/* Status Messages */
.alert-success {
    @apply bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 text-green-800 dark:text-green-200 p-4 rounded-lg;
}

.alert-error {
    @apply bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 text-red-800 dark:text-red-200 p-4 rounded-lg;
}

.alert-warning {
    @apply bg-yellow-50 dark:bg-yellow-900/30 border border-yellow-200 dark:border-yellow-700 text-yellow-800 dark:text-yellow-200 p-4 rounded-lg;
}

.alert-info {
    @apply bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 text-blue-800 dark:text-blue-200 p-4 rounded-lg;
}

/* Responsive Typography */
@layer components {
    .heading-xl {
        @apply text-4xl sm:text-5xl font-bold;
    }

    .heading-lg {
        @apply text-3xl sm:text-4xl font-bold;
    }

    .heading-md {
        @apply text-2xl sm:text-3xl font-bold;
    }

    .text-muted {
        @apply text-gray-600 dark:text-gray-400;
    }

    .text-muted-light {
        @apply text-gray-500 dark:text-gray-500;
    }
}

/* Backdrop Blur Support */
@supports (backdrop-filter: blur(10px)) {
    .backdrop-blur-sm {
        backdrop-filter: blur(4px);
    }
}

/* Print Styles */
@media print {
    body {
        background: white;
    }
    
    .no-print {
        display: none !important;
    }
}